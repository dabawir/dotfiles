{
"layer": "top",
"position": "top",
"height": 24,
"modules-left": [
"custom/nixos",
"custom/sep_os",
"hyprland/workspaces",
"custom/sep_ws"
],
"modules-right": [
"custom/sep_cpu",
"cpu",
"custom/sep_net",
"network",
"custom/sep_vol",
"pulseaudio",
"custom/sep_bat",
"battery",
"custom/sep_date",
"clock#date",
"custom/sep_time",
"clock#time"
],
"custom/nixos": { "format": " пМУ " },
"custom/sep_os": { "format": "оВЉ", "tooltip": false },
"hyprland/workspaces": { 
  "format": "{name}", 
  "on-click": "activate",
  "persistent-workspaces": { "*": 5 }
},
"custom/sep_ws": { "format": "оВЉ", "tooltip": false },
"custom/sep_cpu": { "format": "оВЇ", "tooltip": false },
"cpu": { "format": "пТЉ  {usage}% " },
"custom/sep_net": { "format": "оВЇ", "tooltip": false },
"network": { "format-wifi": "пЗЂ  {essid} ", "format-disconnected": "вЪ† Down " },
"custom/sep_vol": { "format": "оВЇ", "tooltip": false },
"pulseaudio": { "format": "пА®  {volume}% ", "on-click": "pavucontrol" },
"custom/sep_bat": { "format": "оВЇ", "tooltip": false },
"battery": {
  "states": { "warning": 30, "critical": 15 },
  "format": "{icon} {capacity}% ",
  "format-charging": "пГІ {capacity}% ",
  "format-plugged": "пЗ¶ {capacity}% ",
  "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
},
"custom/sep_date": { "format": "оВЇ", "tooltip": false },
"clock#date": { "format": "пСХ {:%Y-%m-%d} " },
"custom/sep_time": { "format": "оВЇ", "tooltip": false },
"clock#time": { "format": "пАЧ {:%H:%M} " }
}
